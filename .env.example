# Copy to .env and fill in real values: cp .env.example .env
# .env is gitignored — never commit the filled-in version.

# ── Database ──────────────────────────────────────────────────────────
DB_NAME=manga
DB_USER=manga
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me_too

# ── Job queue (Redis / RQ) ────────────────────────────────────────────
# utils/job_runner.py uses this for job state, history, and the RQ queue
# itself. Docker Compose sets this automatically to redis://redis:6379/0
# (see docker-compose.yml's `app`/`worker` services) — only needed here for
# non-Docker deployments. Without a worker running against this same URL
# (`rq worker manga-jobs --url $REDIS_URL`), /admin's scrape buttons will
# enqueue jobs that never get picked up.
REDIS_URL=redis://localhost:6379/0

# ── Flask ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace_me
ADMIN_PASSWORD=change_me_admin
# Required for /admin to enforce the password inside Docker — the
# "no password needed from localhost" bypass in backend.py only fires
# when request.remote_addr is 127.0.0.1, which it never is once nginx
# is fronting the app over the docker network.

# Set to "false" only for local HTTP testing without TLS in front of
# nginx — see note in chat about SESSION_COOKIE_SECURE. Leave unset
# (defaults to true) for any deployment that's actually reachable over
# the network.
# SESSION_COOKIE_SECURE=false

# ── MyAnimeList API (optional — only needed for "Update manga list" job
#    and MAL-based filtering on the results page) ───────────────────────
MAL_CLIENT_ID=
MAL_CLIENT_SECRET=
MAL_ACCESS_TOKEN=
MAL_REFRESH_TOKEN=
